# ─────────────────────────────────────────────────────────────
# AllNewspaperBangla — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata, sitemap, redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# From your Supabase project → Settings → API.
# Public (safe to expose) — enables read queries:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY (never expose) — enables admin writes, submissions & click tracking:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Admin panel (/admin) ──────────────────────────────────────
# The secret password for the admin login. Choose something strong.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to sign the admin session cookie (JWT).
# Use a long random string, e.g. `openssl rand -base64 48`.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
